FAL_KEY=your_fal_key_here
ELEVEN_API_KEY=your_elevenlabs_api_key_here

# fal_client.subscribe wait (seconds). InfiniTalk / LTX can queue for a long time; default 3600, clamp 300–7200.
# FAL_CLIENT_TIMEOUT_SEC=3600

# InfiniTalk (fal-ai/infinitalk/video-to-video): num_frames 81–129; resolution 480p or 720p; acceleration none|regular|high
# INFINITALK_NUM_FRAMES=97
# INFINITALK_RESOLUTION=480p
# INFINITALK_ACCELERATION=regular

# CORS (production): comma-separated UI origins, e.g. https://my-app.vercel.app
# CORS_ORIGINS=https://my-app.vercel.app
# Optional regex (matches any Vercel preview + production subdomains pattern):
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# Optional: if ffmpeg is not on PATH (common on Windows), set full paths:
# FFMPEG_PATH=C:\path\to\ffmpeg\bin\ffmpeg.exe
# FFPROBE_PATH=C:\path\to\ffmpeg\bin\ffprobe.exe
